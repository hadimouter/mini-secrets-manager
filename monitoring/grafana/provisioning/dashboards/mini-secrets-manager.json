{
  "title": "Mini Secrets Manager",
  "uid": "mini-secrets-manager",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Secrets Created",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "secrets_created_total",
          "legendFormat": "created"
        }
      ]
    },
    {
      "id": 2,
      "title": "Secrets Read",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "secrets_read_total",
          "legendFormat": "read"
        }
      ]
    },
    {
      "id": 3,
      "title": "Secrets Deleted",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "orange", "value": null }] } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "secrets_deleted_total",
          "legendFormat": "deleted"
        }
      ]
    },
    {
      "id": 4,
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "auth_failures_total",
          "legendFormat": "failures"
        }
      ]
    },
    {
      "id": 5,
      "title": "Auth Failures Rate (5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(auth_failures_total[5m])",
          "legendFormat": "auth failures/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p50 {{route}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p99 {{route}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Secrets Operations Rate (5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(secrets_created_total[5m])",
          "legendFormat": "created/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(secrets_read_total[5m])",
          "legendFormat": "read/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(secrets_deleted_total[5m])",
          "legendFormat": "deleted/s"
        }
      ]
    }
  ]
}
