# Base de données (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m

# Chiffrement AES-256-GCM — générer avec : openssl rand -hex 32
# ⚠️ Ne jamais changer après création des secrets (les rend illisibles)
ENCRYPTION_KEY=

# Monitoring — token pour protéger l'endpoint /metrics
# Générer avec : openssl rand -hex 32
METRICS_TOKEN=

# App
PORT=3000
NODE_ENV=development
